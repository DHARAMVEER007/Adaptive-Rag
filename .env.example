GROQ_API_KEY=gsk_your_groq_api_key_here
TAVILY_API_KEY=tvly_your_tavily_key_here   # optional, only needed for web search

# Auth — REQUIRED. Shared secret used to sign & verify JWTs across the
# auth and backend services. Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE_MINUTES=1440                     # token lifetime (default 24h)

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000
